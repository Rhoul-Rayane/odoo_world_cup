<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============ LIST VIEW ============ -->
    <record id="wc_revenue_stream_view_list" model="ir.ui.view">
        <field name="name">wc.revenue.stream.list</field>
        <field name="model">wc.revenue.stream</field>
        <field name="arch" type="xml">
            <list decoration-success="variance &gt; 0"
                  decoration-danger="variance &lt; 0">
                <field name="name"/>
                <field name="revenue_type" widget="badge" decoration-info="1"/>
                <field name="stadium_id" optional="show"/>
                <field name="period" widget="badge" decoration-warning="1"/>
                <field name="projected_amount" sum="Total projeté"/>
                <field name="actual_amount" sum="Total réalisé"/>
                <field name="variance" sum="Écart total"/>
                <field name="variance_pct"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'forecast'"
                       decoration-primary="state == 'confirmed'"
                       decoration-warning="state == 'invoiced'"
                       decoration-success="state == 'collected'"/>
            </list>
        </field>
    </record>

    <!-- ============ FORM VIEW ============ -->
    <record id="wc_revenue_stream_view_form" model="ir.ui.view">
        <field name="name">wc.revenue.stream.form</field>
        <field name="model">wc.revenue.stream</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirmer"
                            class="btn-primary"
                            invisible="state != 'forecast'"/>
                    <button name="action_invoice" type="object" string="Facturer"
                            class="btn-warning"
                            invisible="state != 'confirmed'"/>
                    <button name="action_collect" type="object" string="Encaisser"
                            class="btn-success"
                            invisible="state != 'invoiced'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="forecast,confirmed,invoiced,collected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Source de revenu"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="revenue_type"/>
                            <field name="period"/>
                            <field name="stadium_id"/>
                            <field name="match_id"/>
                        </group>
                        <group string="Montants (MAD)">
                            <field name="projected_amount"/>
                            <field name="actual_amount"/>
                            <field name="variance"/>
                            <field name="variance_pct"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Notes et commentaires..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ SEARCH VIEW ============ -->
    <record id="wc_revenue_stream_view_search" model="ir.ui.view">
        <field name="name">wc.revenue.stream.search</field>
        <field name="model">wc.revenue.stream</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="stadium_id"/>
                <field name="revenue_type"/>
                <separator/>
                <filter name="filter_ticketing" string="Billetterie" domain="[('revenue_type', '=', 'ticketing')]"/>
                <filter name="filter_sponsorship" string="Sponsoring" domain="[('revenue_type', '=', 'sponsorship')]"/>
                <filter name="filter_broadcasting" string="Droits de diffusion" domain="[('revenue_type', '=', 'broadcasting')]"/>
                <filter name="filter_merchandising" string="Merchandising" domain="[('revenue_type', '=', 'merchandising')]"/>
                <separator/>
                <filter name="filter_q3_2030" string="Période Tournoi (T3 2030)" domain="[('period', '=', 'q3_2030')]"/>
                <filter name="filter_2030" string="Année 2030" domain="[('period', 'in', ['q1_2030', 'q2_2030', 'q3_2030', 'q4_2030'])]"/>
                <separator/>
                <filter name="filter_forecast" string="Prévisionnel" domain="[('state', '=', 'forecast')]"/>
                <filter name="filter_confirmed" string="Confirmé" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_invoiced" string="Facturé" domain="[('state', '=', 'invoiced')]"/>
                <filter name="filter_collected" string="Encaissé" domain="[('state', '=', 'collected')]"/>
                <separator/>
                <filter name="group_revenue_type" string="Type de revenu" context="{'group_by': 'revenue_type'}"/>
                <filter name="group_stadium" string="Stade" context="{'group_by': 'stadium_id'}"/>
                <filter name="group_period" string="Période" context="{'group_by': 'period'}"/>
            </search>
        </field>
    </record>

    <!-- ============ GRAPH VIEW ============ -->
    <record id="wc_revenue_stream_view_graph" model="ir.ui.view">
        <field name="name">wc.revenue.stream.graph</field>
        <field name="model">wc.revenue.stream</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="revenue_type"/>
                <field name="projected_amount" type="measure"/>
                <field name="actual_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============ ACTION ============ -->
    <record id="action_revenue_stream" model="ir.actions.act_window">
        <field name="name">Flux de Revenus</field>
        <field name="res_model">wc.revenue.stream</field>
        <field name="view_mode">list,form,graph</field>
        <field name="search_view_id" ref="wc_revenue_stream_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un nouveau flux de revenu
            </p>
            <p>
                Suivez les revenus projetés et réalisés : billetterie, sponsoring, droits TV et plus.
            </p>
        </field>
    </record>

</odoo>
