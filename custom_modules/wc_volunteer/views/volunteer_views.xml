<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============ VOLUNTEER LIST VIEW ============ -->
    <record id="wc_volunteer_view_list" model="ir.ui.view">
        <field name="name">wc.volunteer.list</field>
        <field name="model">wc.volunteer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="skill_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="language_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="availability"/>
                <field name="assigned_stadium_id"/>
                <field name="matching_score" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'candidate'"
                       decoration-warning="state == 'preselected'"
                       decoration-primary="state == 'trained'"
                       decoration-success="state in ('assigned', 'active')"
                       decoration-muted="state == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- ============ VOLUNTEER FORM VIEW ============ -->
    <record id="wc_volunteer_view_form" model="ir.ui.view">
        <field name="name">wc.volunteer.form</field>
        <field name="model">wc.volunteer</field>
        <field name="arch" type="xml">
            <form string="Volontaire">
                <header>
                    <button name="action_preselect" type="object" string="Présélectionner"
                            class="btn-primary" invisible="state != 'candidate'"/>
                    <button name="action_train" type="object" string="Marquer Formé"
                            class="btn-primary" invisible="state != 'preselected'"/>
                    <button name="action_assign" type="object" string="Valider Affectation"
                            class="btn-primary" invisible="state != 'trained'"/>
                    <button name="action_activate" type="object" string="Activer"
                            class="btn-success" invisible="state != 'assigned'"/>
                    <button name="action_archive_volunteer" type="object" string="Archiver"
                            class="btn-secondary" invisible="state in ('candidate', 'archived')"/>
                    <button name="action_reset_to_candidate" type="object" string="Réinitialiser"
                            class="btn-secondary" invisible="state == 'candidate'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="candidate,preselected,trained,assigned,active"/>
                </header>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom complet du volontaire"/></h1>
                        <h3>
                            <span>Score de matching : </span>
                            <field name="matching_score" widget="progressbar"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Informations personnelles">
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                            <field name="nationality"/>
                            <field name="id_number"/>
                            <field name="address"/>
                        </group>
                        <group string="Compétences &amp; Qualifications">
                            <field name="skill_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="language_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="education_level"/>
                            <field name="has_driving_license"/>
                            <field name="has_vehicle" invisible="not has_driving_license"/>
                            <field name="has_first_aid"/>
                        </group>
                    </group>
                    <group>
                        <group string="Disponibilité &amp; Affectation">
                            <field name="availability"/>
                            <field name="preferred_stadium_id"/>
                            <field name="assigned_stadium_id"/>
                            <field name="assigned_zone_id"/>
                        </group>
                        <group string="Gamification &amp; Suivi">
                            <field name="application_date"/>
                            <field name="training_date"/>
                            <field name="points"/>
                            <field name="badge_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Expérience" name="experience">
                            <field name="experience" placeholder="Décrivez vos expériences bénévoles..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ VOLUNTEER KANBAN VIEW ============ -->
    <record id="wc_volunteer_view_kanban" model="ir.ui.view">
        <field name="name">wc.volunteer.kanban</field>
        <field name="model">wc.volunteer</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="email"/>
                <field name="matching_score"/>
                <field name="state"/>
                <field name="photo"/>
                <field name="skill_ids"/>
                <field name="language_ids"/>
                <templates>
                    <t t-name="card">
                        <field name="photo" widget="image" options="{'size': [80, 80]}"/>
                        <div>
                            <strong><field name="name"/></strong>
                            <div><field name="email"/></div>
                            <div class="mt-1">
                                <field name="skill_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </div>
                            <div class="mt-1">
                                <strong>Score : </strong><field name="matching_score"/>%
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============ VOLUNTEER SEARCH VIEW ============ -->
    <record id="wc_volunteer_view_search" model="ir.ui.view">
        <field name="name">wc.volunteer.search</field>
        <field name="model">wc.volunteer</field>
        <field name="arch" type="xml">
            <search string="Recherche Volontaires">
                <field name="name"/>
                <field name="email"/>
                <field name="skill_ids"/>
                <field name="language_ids"/>
                <field name="assigned_stadium_id"/>
                <field name="state"/>
            </search>
        </field>
    </record>

    <!-- ============ VOLUNTEER ACTION ============ -->
    <record id="wc_volunteer_action" model="ir.actions.act_window">
        <field name="name">Volontaires</field>
        <field name="res_model">wc.volunteer</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>

</odoo>
