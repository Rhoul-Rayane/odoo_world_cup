            <field name="team_b">Espagne</field>
            <field name="stadium_id" ref="wc_base.stadium_hassan_ii"/>
            <field name="date_time" eval="(datetime.now() + timedelta(days=5)).strftime('%Y-%m-%d 20:00:00')"/>
