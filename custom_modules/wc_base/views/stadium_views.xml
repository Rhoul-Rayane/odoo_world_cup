<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============ STADIUM LIST VIEW ============ -->
    <record id="wc_stadium_view_list" model="ir.ui.view">
        <field name="name">wc.stadium.list</field>
        <field name="model">wc.stadium</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'ready'"
                  decoration-warning="state == 'maintenance'"
                  decoration-muted="state == 'construction'">
                <field name="name"/>
                <field name="city"/>
                <field name="country"/>
                <field name="capacity"/>
                <field name="zone_count"/>
                <field name="match_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'ready'"
                       decoration-warning="state == 'maintenance'"
                       decoration-info="state == 'construction'"/>
            </list>
        </field>
    </record>

    <!-- ============ STADIUM FORM VIEW ============ -->
    <record id="wc_stadium_view_form" model="ir.ui.view">
        <field name="name">wc.stadium.form</field>
        <field name="model">wc.stadium</field>
        <field name="arch" type="xml">
            <form string="Stade">
                <header>
                    <button name="action_set_ready" type="object" string="Marquer Prêt"
                            class="btn-primary" invisible="state == 'ready'"/>
                    <button name="action_set_maintenance" type="object" string="En maintenance"
                            class="btn-warning" invisible="state == 'maintenance'"/>
                    <field name="state" widget="statusbar" statusbar_visible="construction,ready"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-th-large"
                                type="object" name="action_view_zones">
                            <field name="zone_count" string="Zones" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-futbol-o"
                                type="object" name="action_view_matches">
                            <field name="match_count" string="Matchs" widget="statinfo"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom du stade"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="city"/>
                            <field name="country"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Zones" name="zones">
                            <field name="zone_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="zone_type"/>
                                    <field name="capacity"/>
                                </list>
                            </field>
                        </page>
                        <page string="Matchs" name="matches">
                            <field name="match_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date_time"/>
                                    <field name="phase"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ STADIUM KANBAN VIEW ============ -->
    <record id="wc_stadium_view_kanban" model="ir.ui.view">
        <field name="name">wc.stadium.kanban</field>
        <field name="model">wc.stadium</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="city"/>
                <field name="capacity"/>
                <field name="state"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <field name="image" widget="image" options="{'size': [100, 100]}"/>
                        <div>
                            <strong><field name="name"/></strong>
                            <div><field name="city"/> - <field name="capacity"/> places</div>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'ready'"
                                   decoration-warning="state == 'maintenance'"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============ STADIUM SEARCH VIEW ============ -->
    <record id="wc_stadium_view_search" model="ir.ui.view">
        <field name="name">wc.stadium.search</field>
        <field name="model">wc.stadium</field>
        <field name="arch" type="xml">
            <search string="Recherche Stades">
                <field name="name"/>
                <field name="city"/>
                <field name="country"/>
                <field name="state"/>
                <separator/>
                <filter string="Prêt" name="filter_ready" domain="[('state', '=', 'ready')]"/>
                <filter string="En construction" name="filter_construction" domain="[('state', '=', 'construction')]"/>
                <filter string="En maintenance" name="filter_maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Pays" name="group_country" context="{'group_by': 'country'}" domain="[]"/>
                <filter string="Statut" name="group_state" context="{'group_by': 'state'}" domain="[]"/>
            </search>
        </field>
    </record>

    <!-- ============ STADIUM ACTION ============ -->
    <record id="wc_stadium_action" model="ir.actions.act_window">
        <field name="name">Stades</field>
        <field name="res_model">wc.stadium</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('country', '=', 'morocco')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer votre premier stade
            </p>
            <p>Ajoutez les stades de la Coupe du Monde 2030.</p>
        </field>
    </record>

</odoo>
