<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="wc_stadium_zone_view_list" model="ir.ui.view">
        <field name="name">wc.stadium.zone.list</field>
        <field name="model">wc.stadium.zone</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="stadium_id"/>
                <field name="zone_type"/>
                <field name="capacity"/>
            </list>
        </field>
    </record>

    <record id="wc_stadium_zone_action" model="ir.actions.act_window">
        <field name="name">Zones de Stade</field>
        <field name="res_model">wc.stadium.zone</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
