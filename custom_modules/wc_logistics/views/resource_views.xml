<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="wc_resource_view_list" model="ir.ui.view">
        <field name="name">wc.logistics.resource.list</field>
        <field name="model">wc.logistics.resource</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'out'" decoration-warning="state == 'low'">
                <field name="name"/>
                <field name="category"/>
                <field name="total_qty"/>
                <field name="available_qty"/>
                <field name="unit"/>
                <field name="stadium_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'low'"
                       decoration-danger="state == 'out'"/>
            </list>
        </field>
    </record>

    <record id="wc_resource_view_form" model="ir.ui.view">
        <field name="name">wc.logistics.resource.form</field>
        <field name="model">wc.logistics.resource</field>
        <field name="arch" type="xml">
            <form string="Ressource">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom de la ressource"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="total_qty"/>
                            <field name="available_qty"/>
                            <field name="unit"/>
                        </group>
                        <group>
                            <field name="stadium_id"/>
                            <field name="zone_id"/>
                            <field name="state" widget="badge"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="wc_resource_view_search" model="ir.ui.view">
        <field name="name">wc.logistics.resource.search</field>
        <field name="model">wc.logistics.resource</field>
        <field name="arch" type="xml">
            <search string="Recherche Ressources">
                <field name="name"/>
                <field name="category"/>
                <field name="stadium_id"/>
                <separator/>
                <filter name="filter_out" string="Rupture" domain="[('state', '=', 'out')]"/>
                <filter name="filter_low" string="Stock faible" domain="[('state', '=', 'low')]"/>
                <filter name="filter_available" string="Disponible" domain="[('state', '=', 'available')]"/>
                <filter name="group_category" string="Catégorie" context="{'group_by': 'category'}" domain="[]"/>
                <filter name="group_stadium" string="Stade" context="{'group_by': 'stadium_id'}" domain="[]"/>
                <filter name="group_state" string="État" context="{'group_by': 'state'}" domain="[]"/>
            </search>
        </field>
    </record>

    <record id="wc_resource_action" model="ir.actions.act_window">
        <field name="name">Ressources</field>
        <field name="res_model">wc.logistics.resource</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
