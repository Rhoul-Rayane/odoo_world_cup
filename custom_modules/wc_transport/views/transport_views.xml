<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============ LIGNES DE TRANSPORT ============ -->
    <record id="view_transport_line_list" model="ir.ui.view">
        <field name="name">wc.transport.line.list</field>
        <field name="model">wc.transport.line</field>
        <field name="arch" type="xml">
            <list string="Lignes de Transport" decoration-muted="not active">
                <field name="name"/>
                <field name="line_type" widget="badge"
                       decoration-info="line_type == 'metro'"
                       decoration-success="line_type == 'tram'"
                       decoration-warning="line_type == 'bus'"
                       decoration-danger="line_type == 'train'"/>
                <field name="capacity_per_hour"/>
                <field name="color" widget="color"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_transport_line_search" model="ir.ui.view">
        <field name="name">wc.transport.line.search</field>
        <field name="model">wc.transport.line</field>
        <field name="arch" type="xml">
            <search string="Rechercher une ligne">
                <field name="name"/>
                <field name="line_type"/>
                <separator/>
                <filter string="Métro" name="filter_metro" domain="[('line_type', '=', 'metro')]"/>
                <filter string="Bus (BRT)" name="filter_bus" domain="[('line_type', '=', 'bus')]"/>
                <filter string="Tramway" name="filter_tram" domain="[('line_type', '=', 'tram')]"/>
                <filter string="Train" name="filter_train" domain="[('line_type', '=', 'train')]"/>
                <separator/>
                <filter string="Actives" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Archivées" name="filter_archived" domain="[('active', '=', False)]"/>
                <filter string="Type" name="groupby_type" context="{'group_by': 'line_type'}" domain="[]"/>
                <filter string="Statut actif" name="groupby_active" context="{'group_by': 'active'}" domain="[]"/>
            </search>
        </field>
    </record>

    <record id="view_transport_line_kanban" model="ir.ui.view">
        <field name="name">wc.transport.line.kanban</field>
        <field name="model">wc.transport.line</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="line_type"/>
                <field name="color"/>
                <field name="capacity_per_hour"/>
                <field name="station_ids"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-center mb-1">
                            <span t-att-style="'display:inline-block;width:12px;height:12px;border-radius:50%;background-color:' + (record.color.raw_value or '#000') + ';margin-right:8px;'"/>
                            <strong>
                                <field name="name"/>
                            </strong>
                        </div>
                        <div class="mb-1">
                            <field name="line_type" widget="badge"
                                   decoration-info="line_type == 'metro'"
                                   decoration-success="line_type == 'tram'"
                                   decoration-warning="line_type == 'bus'"
                                   decoration-danger="line_type == 'train'"/>
                        </div>
                        <div class="text-muted">
                            Capacité : <field name="capacity_per_hour"/> pass./h
                        </div>
                        <div class="text-muted">
                            Stations : <field name="station_ids" widget="many2many_tags"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_transport_line_form" model="ir.ui.view">
        <field name="name">wc.transport.line.form</field>
        <field name="model">wc.transport.line</field>
        <field name="arch" type="xml">
            <form string="Ligne de Transport">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Ex: TGV Al Boraq"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="line_type"/>
                            <field name="capacity_per_hour"/>
                            <field name="color"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Stations desservies">
                            <field name="station_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Plannings Matchs">
                            <field name="schedule_ids">
                                <list string="Plannings liés">
                                    <field name="match_id"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="frequency_minutes"/>
                                    <field name="planned_passengers"/>
                                    <field name="actual_passengers"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_transport_line" model="ir.actions.act_window">
        <field name="name">Lignes de Transport</field>
        <field name="res_model">wc.transport.line</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_transport_line_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre première ligne de transport
            </p>
            <p>Ajoutez des lignes de métro, bus, tramway ou train pour la Coupe du Monde.</p>
        </field>
    </record>

    <!-- ============ STATIONS DE TRANSPORT ============ -->
    <record id="view_transport_station_list" model="ir.ui.view">
        <field name="name">wc.transport.station.list</field>
        <field name="model">wc.transport.station</field>
        <field name="arch" type="xml">
            <list string="Stations de Transport">
                <field name="name"/>
                <field name="code"/>
                <field name="gps_lat"/>
                <field name="gps_lng"/>
                <field name="stadium_id" widget="badge" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_transport_station_search" model="ir.ui.view">
        <field name="name">wc.transport.station.search</field>
        <field name="model">wc.transport.station</field>
        <field name="arch" type="xml">
            <search string="Rechercher une station">
                <field name="name"/>
                <field name="code"/>
                <field name="stadium_id"/>
                <separator/>
                <filter string="Liée à un stade" name="filter_has_stadium" domain="[('stadium_id', '!=', False)]"/>
                <filter string="Sans stade" name="filter_no_stadium" domain="[('stadium_id', '=', False)]"/>
                <filter string="Stade" name="groupby_stadium" context="{'group_by': 'stadium_id'}" domain="[]"/>
            </search>
        </field>
    </record>

    <record id="view_transport_station_form" model="ir.ui.view">
        <field name="name">wc.transport.station.form</field>
        <field name="model">wc.transport.station</field>
        <field name="arch" type="xml">
            <form string="Station de Transport">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Ex: Gare Tanger Ville"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="stadium_id"/>
                        </group>
                        <group>
                            <field name="gps_lat"/>
                            <field name="gps_lng"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lignes passant par cette station">
                            <field name="line_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_transport_station" model="ir.actions.act_window">
        <field name="name">Stations de Transport</field>
        <field name="res_model">wc.transport.station</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transport_station_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Ajoutez votre première station de transport
            </p>
            <p>Définissez les stations de métro, bus, tramway ou train desservant les stades.</p>
        </field>
    </record>

    <!-- ============ ZONES DE PARKING ============ -->
    <record id="view_parking_zone_list" model="ir.ui.view">
        <field name="name">wc.parking.zone.list</field>
        <field name="model">wc.parking.zone</field>
        <field name="arch" type="xml">
            <list string="Zones de Parking"
                  decoration-danger="occupancy_rate &gt; 85"
                  decoration-warning="occupancy_rate &gt; 60 and occupancy_rate &lt;= 85">
                <field name="name"/>
                <field name="stadium_id"/>
                <field name="zone_type" widget="badge"
                       decoration-info="zone_type == 'vip'"
                       decoration-success="zone_type == 'public'"
                       decoration-warning="zone_type == 'media'"
                       decoration-danger="zone_type == 'work'"/>
                <field name="total_capacity"/>
                <field name="available_capacity"/>
                <field name="occupancy_rate" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_parking_zone_search" model="ir.ui.view">
        <field name="name">wc.parking.zone.search</field>
        <field name="model">wc.parking.zone</field>
        <field name="arch" type="xml">
            <search string="Rechercher une zone de parking">
                <field name="name"/>
                <field name="stadium_id"/>
                <field name="zone_type"/>
                <separator/>
                <filter string="Occupation haute (&gt;80%)" name="filter_high_occ"
                        domain="[('occupancy_rate', '&gt;', 80)]"/>
                <filter string="Disponible (&lt;50%)" name="filter_available"
                        domain="[('occupancy_rate', '&lt;', 50)]"/>
                <filter string="Stade" name="groupby_stadium" context="{'group_by': 'stadium_id'}" domain="[]"/>
                <filter string="Catégorie" name="groupby_zone_type" context="{'group_by': 'zone_type'}" domain="[]"/>
            </search>
        </field>
    </record>

    <record id="view_parking_zone_form" model="ir.ui.view">
        <field name="name">wc.parking.zone.form</field>
        <field name="model">wc.parking.zone</field>
        <field name="arch" type="xml">
            <form string="Zone de Parking">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Ex: Parking P1 - VIP"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="stadium_id"/>
                            <field name="zone_type"/>
                        </group>
                        <group>
                            <field name="total_capacity"/>
                            <field name="available_capacity"/>
                            <field name="occupancy_rate" widget="progressbar"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_parking_zone" model="ir.actions.act_window">
        <field name="name">Zones de Parking</field>
        <field name="res_model">wc.parking.zone</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_parking_zone_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Ajoutez votre première zone de parking
            </p>
            <p>Gérez les zones de parking VIP, public, médias et staff autour des stades.</p>
        </field>
    </record>

    <!-- ============ CALENDRIER DE TRANSPORT MATCHS ============ -->
    <record id="view_transport_schedule_list" model="ir.ui.view">
        <field name="name">wc.transport.schedule.list</field>
        <field name="model">wc.transport.schedule</field>
        <field name="arch" type="xml">
            <list string="Plannings de Navettes Matchs"
                  decoration-info="actual_passengers &gt; 0">
                <field name="match_id"/>
                <field name="line_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="frequency_minutes"/>
                <field name="planned_passengers"/>
                <field name="actual_passengers"/>
            </list>
        </field>
    </record>

    <record id="view_transport_schedule_search" model="ir.ui.view">
        <field name="name">wc.transport.schedule.search</field>
        <field name="model">wc.transport.schedule</field>
        <field name="arch" type="xml">
            <search string="Rechercher un planning">
                <field name="match_id"/>
                <field name="line_id"/>
                <separator/>
                <filter string="Avec passagers réels" name="filter_has_passengers"
                        domain="[('actual_passengers', '&gt;', 0)]"/>
                <filter string="Sans passagers réels" name="filter_no_passengers"
                        domain="[('actual_passengers', '=', 0)]"/>
                <separator/>
                <filter string="Aujourd'hui" name="filter_today"
                        domain="[('start_time', '&gt;=', (context_today()).strftime('%Y-%m-%d')),
                                 ('start_time', '&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Match" name="groupby_match" context="{'group_by': 'match_id'}" domain="[]"/>
                <filter string="Ligne" name="groupby_line" context="{'group_by': 'line_id'}" domain="[]"/>
            </search>
        </field>
    </record>

    <record id="view_transport_schedule_calendar" model="ir.ui.view">
        <field name="name">wc.transport.schedule.calendar</field>
        <field name="model">wc.transport.schedule</field>
        <field name="arch" type="xml">
            <calendar string="Calendrier des Navettes"
                      date_start="start_time"
                      date_stop="end_time"
                      color="line_id">
                <field name="match_id"/>
                <field name="line_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_transport_schedule_form" model="ir.ui.view">
        <field name="name">wc.transport.schedule.form</field>
        <field name="model">wc.transport.schedule</field>
        <field name="arch" type="xml">
            <form string="Planning de Navette Match">
                <header>
                    <field name="match_id" widget="statusbar" options="{'clickable': '0'}" readonly="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="match_id"/>
                            <field name="line_id"/>
                            <field name="frequency_minutes"/>
                        </group>
                        <group>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="planned_passengers"/>
                            <field name="actual_passengers"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_transport_schedule" model="ir.actions.act_window">
        <field name="name">Planification Navettes</field>
        <field name="res_model">wc.transport.schedule</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_transport_schedule_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Planifiez les navettes pour un match
            </p>
            <p>Créez des plannings de transport renforcé pour les jours de match.</p>
        </field>
    </record>
</odoo>
